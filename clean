#!/bin/bash

# Question 1: Data cleaning script
# Usage: ./clean trending_videos_unclean.csv

input_file="$1"

# 1. Check if no input file was provided
if [ -z "$input_file" ]; then
    echo "ERROR: No input CSV file provided"
    exit 1
fi

# 2. Check if the file exists in the current directory
if [ ! -f "$input_file" ]; then
    echo "ERROR: Input file not found in the current directory"
    exit 1
fi

# 3. Check if the file has a .csv extension
if [[ "$input_file" != *.csv ]]; then
    echo "ERROR: Input file expected in a CSV format"
    exit 1
fi

# 4. Check if the file is empty
if [ ! -s "$input_file" ]; then
    echo "ERROR: Empty file provided"
    exit 1
fi

# 5. Check if the header has exactly 7 columns
header_column_count=$(head -n 1 "$input_file" | awk -F',' '{print NF}')

if [ "$header_column_count" -ne 7 ]; then
    echo "ERROR: Expected 7 columns in the header"
    exit 1
fi

# Clean the data and print the cleaned CSV to standard output.
# Cleaning steps:
# 1. Remove the ratings_disabled column.
# 2. Remove rows that contain any empty fields.
# 3. Remove duplicate rows.
# 4. Remove rows where likes or dislikes are zero.
# 5. Remove time from the publish_date column.

awk -F',' '
BEGIN {
    OFS = ","
}

NR == 1 {
    # Print header without the 7th column, ratings_disabled
    print $1, $2, $3, $4, $5, $6
    next
}

{
    # Skip rows that do not have exactly 7 fields
    if (NF != 7) {
        next
    }

    # Skip rows that contain any empty field
    has_empty_field = 0
    for (i = 1; i <= NF; i++) {
        if ($i == "") {
            has_empty_field = 1
        }
    }

    if (has_empty_field == 1) {
        next
    }

    # Skip rows where likes or dislikes are zero
    if ($4 == 0 || $5 == 0) {
        next
    }

    # Remove time from publish_date
    split($2, date_parts, "T")
    $2 = date_parts[1]

    # Build cleaned row without ratings_disabled column
    cleaned_row = $1 OFS $2 OFS $3 OFS $4 OFS $5 OFS $6

    # Print only unique rows
    if (!(cleaned_row in seen)) {
        seen[cleaned_row] = 1
        print cleaned_row
    }
}
' "$input_file"
